---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookCard from '../components/BookCard.astro';
import { getBooks, getRecentBooks } from '../lib/api';
import { rankingConfig } from '../lib/rankings';

const [topBooks, recentBooks] = await Promise.all([
  getBooks({ sort: 'top_rated', limit: 10, source: 'both' }),
  getRecentBooks({ days: 30, limit: 8, source: 'both' }),
]);

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Fantasy Ranked",
  "url": "https://fantasyranked.com",
  "description": "Power fantasy and system apocalypse rankings, updated weekly. LitRPG, progression fantasy, isekai, and harem fantasy."
};

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Fantasy Ranked",
  "url": "https://fantasyranked.com",
  "description": "Cross-genre power fantasy rankings covering LitRPG, progression fantasy, cultivation, and harem fiction.",
  "parentOrganization": {
    "@type": "Organization",
    "name": "Pivot Press Publishing",
    "url": "https://litrpgtools.com",
    "subOrganization": [
      { "@type": "Organization", "name": "LitRPG Critic", "url": "https://litrpgcritic.com" },
      { "@type": "Organization", "name": "HaremLit Guide", "url": "https://haremlitguide.com" },
      { "@type": "Organization", "name": "Fantasy Ranked", "url": "https://fantasyranked.com" },
      { "@type": "Organization", "name": "LitRPGTools.com", "url": "https://litrpgtools.com" },
      { "@type": "Organization", "name": "Harem-Lit.com", "url": "https://harem-lit.com" }
    ]
  },
  "isPartOf": { "@type": "WebSite", "name": "LitRPGTools.com", "url": "https://litrpgtools.com" },
  "knowsAbout": ["Power Fantasy", "LitRPG", "Progression Fantasy", "System Apocalypse", "Isekai", "Cultivation Fiction", "Harem Fantasy"]
};
---

<BaseLayout
  title="Fantasy Ranked — Power Fantasy & LitRPG Rankings"
  description="The definitive power fantasy rankings. LitRPG, progression fantasy, system apocalypse, and isekai — ranked by reader ratings and updated weekly."
  schema={[websiteSchema, orgSchema]}
>
  <!-- Hero -->
  <section class="border-b border-[#2e2e2e] py-12 px-4">
    <div class="max-w-5xl mx-auto">
      <p class="text-sm font-semibold text-[#f59e0b] uppercase tracking-wider mb-3">Power Fantasy Rankings</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-white leading-tight max-w-2xl">
        The best power fantasy books, ranked.
      </h1>
      <p class="mt-4 text-lg text-[#888] max-w-xl">
        LitRPG, progression fantasy, system apocalypse, isekai, and harem fantasy — all in one place. Updated weekly from community ratings.
      </p>
      <div class="flex flex-wrap gap-3 mt-6">
        <a href="/rankings" class="bg-[#f59e0b] hover:bg-[#d97706] text-black font-semibold px-5 py-2.5 rounded transition-colors">
          Browse Rankings
        </a>
        <a href="/new-releases" class="border border-[#2e2e2e] hover:border-[#f59e0b]/50 text-[#888] hover:text-white px-5 py-2.5 rounded font-medium transition-colors">
          New Releases
        </a>
      </div>
    </div>
  </section>

  <div class="max-w-5xl mx-auto px-4 py-10 grid grid-cols-1 lg:grid-cols-3 gap-10">

    <!-- Main column -->
    <div class="lg:col-span-2 space-y-12">

      <!-- Recent additions -->
      {recentBooks.length > 0 && (
        <section>
          <div class="flex items-center justify-between mb-5">
            <h2 class="text-xl font-bold text-white">Recent Additions</h2>
            <a href="/new-releases" class="text-sm text-[#f59e0b] hover:underline">See all →</a>
          </div>
          <div class="bg-[#1a1a1a] border border-[#2e2e2e] rounded-lg px-4">
            {recentBooks.map(book => (
              <BookCard book={book} showDescription={false} />
            ))}
          </div>
        </section>
      )}

      <!-- Genre quick links -->
      <section>
        <h2 class="text-xl font-bold text-white mb-5">Browse by Category</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          {[
            { label: 'Power Fantasy', href: '/rankings/top-power-fantasy-books' },
            { label: 'System Apocalypse', href: '/rankings/best-system-apocalypse' },
            { label: 'Isekai', href: '/rankings/best-isekai-novels' },
            { label: 'New LitRPG', href: '/rankings/new-litrpg-releases' },
            { label: 'Harem Fantasy', href: '/rankings/new-harem-fantasy-releases' },
          ].map(({ label, href }) => (
            <a
              href={href}
              class="bg-[#1a1a1a] border border-[#2e2e2e] hover:border-[#f59e0b]/40 rounded-lg p-4 text-sm font-medium text-[#888] hover:text-white transition-colors"
            >
              {label} →
            </a>
          ))}
        </div>
      </section>
    </div>

    <!-- Sidebar: Top 10 this week -->
    <aside class="space-y-8">
      <section class="bg-[#1a1a1a] border border-[#2e2e2e] rounded-lg p-5">
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-bold text-white">Top Ranked</h2>
          <a href="/rankings/top-power-fantasy-books" class="text-xs text-[#f59e0b] hover:underline">Full list →</a>
        </div>
        {topBooks.length > 0 ? (
          <div class="divide-y divide-[#2e2e2e]">
            {topBooks.map((book, i) => (
              <BookCard book={book} rank={i + 1} />
            ))}
          </div>
        ) : (
          <p class="text-sm text-[#666] py-4 text-center">Loading rankings…</p>
        )}
      </section>
    </aside>
  </div>
</BaseLayout>
