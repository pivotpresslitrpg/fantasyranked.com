---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Privacy Policy"
  description="Fantasy Ranked privacy policy."
>
  <div class="max-w-2xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-white mb-8">Privacy Policy</h1>
    <div class="prose prose-invert space-y-4 text-[#aaa] leading-relaxed">
      <p>Fantasy Ranked is a static editorial website. We do not collect personal data, require accounts, or use tracking cookies.</p>
      <h2>Analytics</h2>
      <p>We use <a href="https://plausible.io" target="_blank" rel="noopener">Plausible Analytics</a>, a privacy-respecting analytics platform that does not use cookies and does not collect personally identifiable information. No data is shared with third parties.</p>
      <h2>Affiliate Links</h2>
      <p>This site contains Amazon affiliate links. Clicking these links may result in a cookie being set by Amazon. Please refer to Amazon's privacy policy for details.</p>
      <h2>Contact</h2>
      <p>Questions? Email <a href="mailto:hello@fantasyranked.com">hello@fantasyranked.com</a>.</p>
    </div>
  </div>
</BaseLayout>
