---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Contact Fantasy Ranked with questions, corrections, or book recommendations."
>
  <div class="max-w-xl mx-auto px-4 py-12">
    <p class="text-sm font-semibold text-[#f59e0b] uppercase tracking-wider mb-3">Contact</p>
    <h1 class="text-3xl font-bold text-white mb-4">Get in Touch</h1>
    <p class="text-[#888] mb-8">
      Have a book recommendation, a correction to a ranking, or a general inquiry?
      Reach us at <a href="mailto:hello@fantasyranked.com" class="text-[#f59e0b] hover:underline">hello@fantasyranked.com</a>.
    </p>
    <p class="text-[#888] text-sm">
      For questions about LitRPGTools.com or Harem-Lit.com, please use the contact forms on those sites directly.
    </p>
  </div>
</BaseLayout>
