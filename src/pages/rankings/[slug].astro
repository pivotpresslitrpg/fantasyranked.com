---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookCard from '../../components/BookCard.astro';
import { getBooks, getRecentBooks } from '../../lib/api';
import { rankingConfig } from '../../lib/rankings';

export async function getStaticPaths() {
  const { rankingConfig } = await import('../../lib/rankings');
  return Object.keys(rankingConfig).map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const config = rankingConfig[slug];

if (!config) {
  return Astro.redirect('/rankings', 301);
}

// New release rankings use recent-books endpoint
const isNewReleases = slug.startsWith('new-');
const books = isNewReleases
  ? await getRecentBooks({ days: 60, limit: config.limit, source: config.source })
  : await getBooks({ genre: config.genre, sort: config.sort, limit: config.limit, source: config.source });

const listSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": config.title,
  "description": config.description,
  "url": `https://fantasyranked.com/rankings/${slug}`,
  "numberOfItems": books.length,
  "itemListElement": books.slice(0, 20).map((book, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": book.title,
    "url": book.amazon_url || `https://www.amazon.com/s?k=${encodeURIComponent(book.title)}`
  }))
};

const faqSchema = config.faq?.length ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": config.faq.map(({ q, a }) => ({
    "@type": "Question",
    "name": q,
    "acceptedAnswer": { "@type": "Answer", "text": a }
  }))
} : null;
---

<BaseLayout
  title={config.title}
  description={config.description}
  schema={listSchema}
>
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head-extra" />}

  <div class="max-w-3xl mx-auto px-4 py-10">
    <a href="/rankings" class="text-sm text-[#555] hover:text-[#f59e0b] transition-colors">← All Rankings</a>

    <p class="text-sm font-semibold text-[#f59e0b] uppercase tracking-wider mt-4 mb-2">
      {isNewReleases ? 'New Releases' : 'Ranked List'}
    </p>
    <h1 class="text-3xl sm:text-4xl font-bold text-white leading-tight mb-4">{config.title}</h1>

    <!-- Intro -->
    <div class="text-[#999] leading-relaxed mb-6 space-y-4">
      {config.intro.split('\n\n').map(para => (
        <p>{para.trim()}</p>
      ))}
    </div>

    <p class="text-xs text-[#555] mb-8">
      {books.length} books · {isNewReleases ? 'Sorted by date added' : 'Ranked by community rating'} ·
      Data from <a href="https://litrpgtools.com" target="_blank" rel="noopener" class="hover:text-[#f59e0b]">LitRPGTools.com</a>
      {config.source === 'harem' || config.source === 'both' ? (
        <> &amp; <a href="https://harem-lit.com" target="_blank" rel="noopener" class="hover:text-[#f59e0b]">Harem-Lit.com</a></>
      ) : null}
    </p>

    <!-- Book list -->
    <div class="bg-[#1a1a1a] border border-[#2e2e2e] rounded-lg px-4">
      {books.length > 0 ? (
        books.map((book, i) => (
          <BookCard book={book} rank={isNewReleases ? undefined : i + 1} showDescription={true} />
        ))
      ) : (
        <p class="py-8 text-center text-[#666]">No books found for this ranking.</p>
      )}
    </div>

    <!-- FAQ section -->
    {config.faq && config.faq.length > 0 && (
      <section class="mt-14">
        <h2 class="text-xl font-bold text-white mb-6">Frequently Asked Questions</h2>
        <div class="space-y-6">
          {config.faq.map(({ q, a }) => (
            <div class="border-b border-[#2e2e2e] pb-6 last:border-0">
              <h3 class="font-semibold text-white mb-2">{q}</h3>
              <p class="text-[#999] leading-relaxed text-sm">{a}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Other rankings -->
    <section class="mt-12 bg-[#1a1a1a] border border-[#2e2e2e] rounded-lg p-5">
      <h2 class="font-bold text-white mb-3 text-sm uppercase tracking-wider">More Rankings</h2>
      <ul class="space-y-2 text-sm">
        {Object.entries(rankingConfig)
          .filter(([s]) => s !== slug)
          .slice(0, 5)
          .map(([s, c]) => (
            <li>
              <a href={`/rankings/${s}`} class="text-[#888] hover:text-[#f59e0b] transition-colors">{c.title}</a>
            </li>
          ))}
      </ul>
    </section>
  </div>
</BaseLayout>
