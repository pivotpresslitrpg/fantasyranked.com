---
import BaseLayout from '../layouts/BaseLayout.astro';

const thisMonth = new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
---

<BaseLayout
  title={`New Power Fantasy & LitRPG Releases — ${thisMonth}`}
  description="The latest power fantasy, LitRPG, and harem fantasy releases. Browse the full new releases calendar on LitRPGTools.com and Harem-Lit.com."
>
  <div class="max-w-3xl mx-auto px-4 py-10">
    <p class="text-sm font-semibold text-[#f59e0b] uppercase tracking-wider mb-2">New Releases</p>
    <h1 class="text-3xl font-bold text-white mb-3">Latest Power Fantasy &amp; LitRPG Releases</h1>
    <p class="text-[#888] mb-10 leading-relaxed">
      New releases are tracked live across our sister platforms — browse the full catalogs of LitRPG, progression fantasy,
      cultivation, system apocalypse, and harem fantasy, updated continuously.
    </p>

    <div class="grid sm:grid-cols-2 gap-5 mb-10">
      <div class="bg-[#1a1a1a] border border-[#2e2e2e] rounded-xl p-7 text-center flex flex-col">
        <p class="text-white text-base font-semibold mb-1">LitRPG &amp; Progression Fantasy</p>
        <p class="text-[#888] text-sm mb-5 flex-1">
          LitRPG, progression fantasy, dungeon core, system apocalypse, GameLit — full releases calendar on LitRPGTools.com.
        </p>
        <a
          href="https://litrpgtools.com/new-releases"
          target="_blank"
          rel="noopener"
          class="inline-block px-5 py-2.5 bg-[#f59e0b] hover:bg-[#d97706] text-white font-semibold rounded-lg transition-colors text-sm"
        >
          LitRPGTools.com &rarr;
        </a>
      </div>
      <div class="bg-[#1a1a1a] border border-[#2e2e2e] rounded-xl p-7 text-center flex flex-col">
        <p class="text-white text-base font-semibold mb-1">Harem Fantasy &amp; Cultivation</p>
        <p class="text-[#888] text-sm mb-5 flex-1">
          Harem LitRPG, cultivation, and men's romance fantasy — full releases calendar on Harem-Lit.com.
        </p>
        <a
          href="https://harem-lit.com/new-releases"
          target="_blank"
          rel="noopener"
          class="inline-block px-5 py-2.5 bg-[#ec4899] hover:bg-[#db2777] text-white font-semibold rounded-lg transition-colors text-sm"
        >
          Harem-Lit.com &rarr;
        </a>
      </div>
    </div>

    <div class="bg-[#1a1a1a] border border-[#2e2e2e] rounded-lg p-5">
      <p class="text-white font-semibold text-sm mb-3">Browse Our Rankings</p>
      <ul class="space-y-2 text-sm">
        <li><a href="/rankings/top-power-fantasy-books" class="text-[#888] hover:text-[#f59e0b] transition-colors">Top 100 Power Fantasy Books</a></li>
        <li><a href="/rankings/best-system-apocalypse" class="text-[#888] hover:text-[#f59e0b] transition-colors">Best System Apocalypse Series</a></li>
        <li><a href="/rankings/best-isekai-novels" class="text-[#888] hover:text-[#f59e0b] transition-colors">Best Isekai Novels</a></li>
      </ul>
    </div>
  </div>
</BaseLayout>
